    @Environment(\.modelContext) private var modelContext
    @EnvironmentObject private var coordinator: SCAppCoordinator

    @Query private var settings: [SCUserSettings]
    @Query private var recalls: [SCRecallAlert]

    @StateObject private var loc = SCLocationManager.shared

    @State private var liveLines: [String] = []
    @State private var scanStatus: String = "Point camera at product label..."
    @State private var foundIssue: SCStoredScan?
    @State private var showSaveConfirmation = false

    @State private var didSaveThisIssue = false

    var body: some View {
        NavigationStack {
            ZStack {
                SCTheme.backgroundGradient(isDark: isDarkMode).ignoresSafeArea()

                VStack(spacing: 20) {
                    headerSection
                    cameraSection
                    controlsSection
                }
            }
            .toolbar {
                ToolbarItem(placement: .topBarTrailing) {
                    Button {
                        coordinator.activeSheet = .toastDebug
                    } label: {
                        Image(systemName: "bolt.circle")
                    }
                    .accessibilityLabel("Debug tools")
                }
            }
            .onChange(of: liveLines) { _, newValue in
                analyzeLiveText(lines: newValue)
            }
            .overlay(alignment: .top) {
                if showSaveConfirmation {
                    saveConfirmationBanner
                }
            }
            .onAppear {
                // Keep location fresh (Map & report pipeline)
                loc.requestWhenInUse()
                loc.start()
                ensureDefaultSettings()
            }
        }
    }

    // MARK: - Header
    private var headerSection: some View {
        VStack(alignment: .leading, spacing: 4) {
            Text("SHELFCHECK")
                .font(.largeTitle.weight(.black))
                .foregroundStyle(SCTheme.justiceRed)
            Text("Decode the truth. Protect the community.")
                .font(.caption)
                .foregroundStyle(SCTheme.textSecondary(isDark: isDarkMode))
        }
        .frame(maxWidth: .infinity, alignment: .leading)
        .padding(.horizontal)
    }

    // MARK: - Camera
    private var cameraSection: some View {
        ZStack {
            if DataScannerViewController.isSupported && DataScannerViewController.isAvailable {
                SCDataScannerView(
                    recognizedTextLines: $liveLines,
                    onTapCapture: { processCapture() }
                )
                .clipShape(RoundedRectangle(cornerRadius: 20))
                .overlay(
                    RoundedRectangle(cornerRadius: 20)
                        .stroke(foundIssue != nil ? foundIssue!.status.color : SCTheme.truthBlue, lineWidth: 3)
                )

                VStack {
                    Spacer()
                    if let issue = foundIssue {
                        VStack(spacing: 10) {
                            ScanAlertOverlay(result: issue)

                            HStack(spacing: 10) {
                                Button {
                                    coordinator.openScanDetail(scanId: issue.id)
                                } label: {
                                    Label("Details", systemImage: "info.circle.fill")
                                        .frame(maxWidth: .infinity)
                                        .padding()
                                        .background(.black.opacity(0.25))
                                        .foregroundStyle(.white)
                                        .cornerRadius(12)
                                }

                                Button {
                                    coordinator.openReportWizard(scanId: issue.id)
                                } label: {
                                    Label("Report", systemImage: "exclamationmark.bubble.fill")
                                        .frame(maxWidth: .infinity)
                                        .padding()
                                        .background(.black.opacity(0.25))
                                        .foregroundStyle(.white)
                                        .cornerRadius(12)
                                }
                                .disabled(issue.status == .fresh || issue.status == .unknown)
                                .opacity((issue.status == .fresh || issue.status == .unknown) ? 0.5 : 1.0)
                            }
                            .padding(.horizontal)
                            .padding(.bottom, 12)
                        }
                        .transition(.move(edge: .bottom).combined(with: .opacity))
                    } else {
                        statusBubble
                    }
                }
            } else {
                cameraUnavailableView
            }
        }
        .frame(height: 430)
        .shadow(radius: 10)
        .padding(.horizontal)
    }

    private var statusBubble: some View {
        Text(scanStatus)
            .font(.caption)
            .padding(8)
            .background(.ultraThinMaterial)
            .cornerRadius(8)
            .padding(.bottom, 20)
    }

    private var cameraUnavailableView: some View {
        VStack(spacing: 14) {
            Image(systemName: "camera.fill")
                .font(.system(size: 50))
                .foregroundStyle(.secondary)
