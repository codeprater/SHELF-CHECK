// MARK: - (4) Recall Service (openFDA) + Upsert

enum SCRecallService {
    struct RecallDTO: Codable {
        let id: String
        let product: String
        let reason: String
        let dateIssued: Date
        let lotCodes: [String]
        let source: String
    }

    // openFDA endpoint for food enforcement
    // NOTE: We keep this resilient and optional; app still works offline.
    static func fetchRecentRecalls(limit: Int) async throws -> [RecallDTO] {
        // Example query: last 60 days, limit N
        // openFDA uses JSON; we parse defensively.
        let urlStr = "https://api.fda.gov/food/enforcement.json?search=report_date:[NOW-60DAY%20TO%20NOW]&limit=\(min(max(limit, 1), 100))"
        guard let url = URL(string: urlStr) else { return [] }

        var req = URLRequest(url: url, cachePolicy: .reloadIgnoringLocalCacheData, timeoutInterval: 20)
        req.httpMethod = "GET"

        let (data, _) = try await URLSession.shared.data(for: req)
        let decoded = try JSONSerialization.jsonObject(with: data) as? [String: Any]
        let results = decoded?["results"] as? [[String: Any]] ?? []

        var out: [RecallDTO] = []
        let iso = ISO8601DateFormatter()
        iso.formatOptions = [.withFullDate]

        for item in results {
            // openFDA keys can vary; extract safely
            let recallNumber = (item["recall_number"] as? String) ?? (item["event_id"] as? String) ?? UUID().uuidString
            let product = (item["product_description"] as? String) ?? "Unknown product"
            let reason = (item["reason_for_recall"] as? String) ?? "Recall reason not provided"
            let reportDateRaw = (item["report_date"] as? String) ?? ""

            let dateIssued: Date = {
                if let d = iso.date(from: reportDateRaw) { return d }
                // fallback: try yyyyMMdd
                if reportDateRaw.count == 8 {
                    let y = Int(reportDateRaw.prefix(4)) ?? 2000
                    let m = Int(reportDateRaw.dropFirst(4).prefix(2)) ?? 1
                    let d = Int(reportDateRaw.suffix(2)) ?? 1
                    var c = DateComponents()
                    c.year = y; c.month = m; c.day = d
                    return Calendar.current.date(from: c) ?? Date()
                }
                return Date()
            }()

            // lot codes (may be in "code_info" as free text)
            let codeInfo = (item["code_info"] as? String) ?? ""
            let lots = extractLotLikeTokens(from: codeInfo)

            out.append(RecallDTO(id: recallNumber, product: product, reason: reason, dateIssued: dateIssued, lotCodes: lots, source: "openFDA"))
        }

        return out
    }

    static func upsertRecalls(_ dtos: [RecallDTO], modelContext: ModelContext) {
        guard !dtos.isEmpty else { return }

        for dto in dtos {
            let fetch = FetchDescriptor<SCRecallAlert>(predicate: #Predicate { $0.id == dto.id })
            if let existing = try? modelContext.fetch(fetch).first {
                existing.product = dto.product
                existing.reason = dto.reason
                existing.dateIssued = dto.dateIssued
                existing.source = dto.source
                existing.lotCodes = dto.lotCodes
            } else {
                let alert = SCRecallAlert(id: dto.id, product: dto.product, reason: dto.reason, dateIssued: dto.dateIssued, source: dto.source, lotCodes: dto.lotCodes)
                modelContext.insert(alert)
            }
        }
        try? modelContext.save()
    }

    private static func extractLotLikeTokens(from text: String) -> [String] {
        // crude but effective: split on whitespace/punct, keep alphanumerics length >= 4
        let separators = CharacterSet.alphanumerics.inverted
        let tokens = text.components(separatedBy: separators).filter { $0.count >= 4 }
        // Keep unique, uppercase
        var seen = Set<String>()
        var out: [String] = []
        for t in tokens {
            let u = t.uppercased()
            if !seen.contains(u) {
                seen.insert(u)
                out.append(u)
            }
        }
        return out.prefix(20).map { $0 }
    }
}

// MARK: - Notifications

enum SCNotifications {
    static func ensureCategories() {
        let expiry = UNNotificationCategory(identifier: "expiry_reminder", actions: [], intentIdentifiers: [], options: [])
        let recall = UNNotificationCategory(identifier: "recall_alert", actions: [], intentIdentifiers: [], options: [])
        UNUserNotificationCenter.current().setNotificationCategories([expiry, recall])
    }

    static func requestAuthIfNeeded(coordinator: SCAppCoordinator) async {
        let center = UNUserNotificationCenter.current()
        let settings = await center.notificationSettings()
        if settings.authorizationStatus == .authorized { return }
        if settings.authorizationStatus == .denied {
            await MainActor.run {
                coordinator.presentAlert(title: "Notifications Disabled", message: "Enable notifications in Settings to get reminders and recall alerts.", settingsLink: true)
            }
            return
        }
        do {
            let granted = try await center.requestAuthorization(options: [.alert, .badge, .sound])
            if !granted {
                await MainActor.run {
                    coordinator.presentAlert(title: "Not Enabled", message: "Notifications weren't enabled. You can turn them on later in Settings.")
                }
            }
        } catch {
            await MainActor.run {
                coordinator.presentAlert(title: "Notification Error", message: "Could not request notifications. Try again.")
            }
        }
    }

    static func scheduleExpiryReminder(scanId: UUID, fireDate: Date, title: String, body: String) {
        let content = UNMutableNotificationContent()
        content.title = title
        content.body = body
        content.sound = .default
        content.categoryIdentifier = "expiry_reminder"
        content.userInfo = ["scanId": scanId.uuidString]

        let trigger = UNCalendarNotificationTrigger(dateMatching: Calendar.current.dateComponents([.year, .month, .day], from: fireDate), repeats: false)
        let req = UNNotificationRequest(identifier: "expiry:\(scanId.uuidString)", content: content, trigger: trigger)
        UNUserNotificationCenter.current().add(req)
    }
}

