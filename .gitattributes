    // MARK: - Logic

    private func ensureDefaultSettings() {
        if settings.isEmpty {
            modelContext.insert(SCUserSettings())
        }
    }

    private func resetScan() {
        withAnimation {
            foundIssue = nil
            liveLines = []
            scanStatus = "Point camera at product label..."
            didSaveThisIssue = false
        }
        UIImpactFeedbackGenerator(style: .light).impactOccurred()
    }

    private func analyzeLiveText(lines: [String]) {
        // 1) Misbrand / bulk-break patterns
        for line in lines {
            let upper = line.uppercased()
            if upper.contains("NOT FOR INDIVIDUAL") || upper.contains("NOT FOR RESALE") || upper.contains("NOT FOR SEPARATE") {
                let result = SCStoredScan(rawText: line, decodedDate: nil, confidence: 0.70, formatUsed: "Keyword Rule", matchedSubstring: line, status: .misbranded)
                withAnimation { foundIssue = applyRecallMatchIfNeeded(result) }
                UINotificationFeedbackGenerator().notificationOccurred(.warning)
                return
            }
        }

        // 2) Date decode patterns
        for line in lines {
            if let decoded = SCLotCodeDecoder.decode(text: line) {
                let today = Date()
                let status: SCScanStatus

                if decoded.date < today {
                    status = .expired
                } else if decoded.date.timeIntervalSinceNow < (86400 * 30) {
                    status = .warning
                } else {
                    status = .fresh
                }

                let result = SCStoredScan(
                    rawText: line,
                    decodedDate: decoded.date,
                    confidence: decoded.confidence,
                    formatUsed: decoded.formatUsed,
                    matchedSubstring: decoded.matchedSubstring,
                    status: status
                )

                withAnimation { foundIssue = applyRecallMatchIfNeeded(result) }

                if status == .expired {
                    UINotificationFeedbackGenerator().notificationOccurred(.error)
                } else if status == .warning {
                    UINotificationFeedbackGenerator().notificationOccurred(.warning)
                } else {
                    UINotificationFeedbackGenerator().notificationOccurred(.success)
                }
                return
            }
        }

        // 3) Nothing found → keep guidance
        scanStatus = "Scanning… look for 'Best By', lot codes, or resale restrictions."
    }

    private func applyRecallMatchIfNeeded(_ scan: SCStoredScan) -> SCStoredScan {
        // (4) Recall matching: light heuristic against cached recalls
        guard !recalls.isEmpty else { return scan }
        let hay = (scan.rawText + " " + (scan.productBrand ?? "")).lowercased()

        let match = recalls.first(where: { alert in
            let needle = alert.product.lowercased()
            if hay.contains(needle) { return true }
            // lot code match: any lot code included in the scanned line
            return alert.lotCodes.contains(where: { code in
                !code.isEmpty && hay.contains(code.lowercased())
            })
        })

        if match != nil {
            scan.status = .recalled
        }
        return scan
    }

    private func processCapture() {
        guard let issue = foundIssue else { return }
        guard !didSaveThisIssue else {
            coordinator.presentToast("Already saved", symbol: "info.circle.fill")
            return
        }

        // attach location at capture time
        if let loc = loc.lastKnownLocation {
            issue.locationLat = loc.coordinate.latitude
            issue.locationLong = loc.coordinate.longitude
        }

        modelContext.insert(issue)
        didSaveThisIssue = true

        UINotificationFeedbackGenerator().notificationOccurred(.success)
        withAnimation { showSaveConfirmation = true }
        coordinator.presentToast("Scan saved", symbol: "checkmark.circle.fill")

        DispatchQueue.main.asyncAfter(deadline: .now() + 1.8) {
            withAnimation { showSaveConfirmation = false }
        }

        // (2) If actionable status, nudge user into detail/actions
        if issue.status == .expired || issue.status == .misbranded || issue.status == .recalled {
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.25) {
                coordinator.openScanDetail(scanId: issue.id)
            }
        }
    }
}

