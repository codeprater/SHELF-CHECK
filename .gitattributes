// MARK: - Lot Code Decoder Engine (Explainable)

struct SCLotCodeDecoder {

    struct DecodedResult {
        let date: Date
        let confidence: Double
        let formatUsed: String
        let matchedSubstring: String
    }

    static func decode(text: String) -> DecodedResult? {
        let cleaned = text.uppercased().replacingOccurrences(of: " ", with: "")

        // 1) Julian Date (YDDD) — ex: 6032 => 2026 + day 032
        if let match = cleanMatch(pattern: "\\b([4-9])([0-3][0-9]{2})\\b", in: cleaned) {
            if let yearDigit = Int(match[1]), let dayOfYear = Int(match[2]) {
                let year = 2020 + yearDigit
                if dayOfYear >= 1 && dayOfYear <= 366,
                   let date = dateFromYearDay(year: year, day: dayOfYear) {
                    return DecodedResult(date: date, confidence: 0.80, formatUsed: "Julian (YDDD)", matchedSubstring: match[0])
                }
            }
        }

        // 2) Standard (MMDDYY / MM-DD-YY / etc.)
        if let match = cleanMatch(pattern: "\\b(0[1-9]|1[0-2])[-/.]?([0-3][0-9])[-/.]?(2[3-9])\\b", in: cleaned) {
            if let month = Int(match[1]), let day = Int(match[2]), let yearShort = Int(match[3]) {
                let year = 2000 + yearShort
                var components = DateComponents()
                components.year = year
                components.month = month
                components.day = day
                if let date = Calendar.current.date(from: components) {
                    return DecodedResult(date: date, confidence: 0.90, formatUsed: "Standard (MM/DD/YY)", matchedSubstring: match[0])
                }
            }
        }

        // 3) YYMMDD — ex: 260120 => 2026-01-20
        if let match = cleanMatch(pattern: "\\b(2[3-9])(0[1-9]|1[0-2])([0-3][0-9])\\b", in: cleaned) {
            if let yearShort = Int(match[1]), let month = Int(match[2]), let day = Int(match[3]) {
                let year = 2000 + yearShort
                var components = DateComponents()
                components.year = year
                components.month = month
                components.day = day
                if let date = Calendar.current.date(from: components) {
                    return DecodedResult(date: date, confidence: 0.85, formatUsed: "YYMMDD", matchedSubstring: match[0])
                }
            }
        }

        return nil
    }

    private static func cleanMatch(pattern: String, in text: String) -> [String]? {
        guard let regex = try? NSRegularExpression(pattern: pattern) else { return nil }
        let nsString = text as NSString
        let range = NSRange(location: 0, length: nsString.length)
        guard let match = regex.firstMatch(in: text, range: range) else { return nil }
        var results: [String] = []
        for i in 0..<match.numberOfRanges {
            results.append(nsString.substring(with: match.range(at: i)))
        }
        return results
    }

    private static func dateFromYearDay(year: Int, day: Int) -> Date? {
        var components = DateComponents()
        components.year = year
        components.month = 1
        components.day = 1
        guard let startOfYear = Calendar.current.date(from: components) else { return nil }
        return Calendar.current.date(byAdding: .day, value: day - 1, to: startOfYear)
    }
}

