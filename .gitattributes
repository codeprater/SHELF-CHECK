// Global overlays: coordinator sheets/alerts/toasts (continuity)
extension View {
    func scGlobalOverlays() -> some View {
        modifier(SCGlobalOverlayModifier())
    }
}

struct SCGlobalOverlayModifier: ViewModifier {
    @EnvironmentObject private var coordinator: SCAppCoordinator

    func body(content: Content) -> some View {
        content
            .alert(coordinator.alertTitle, isPresented: $coordinator.showingAlert) {
                Button("OK", role: .cancel) {}
                if coordinator.alertHasSettingsLink {
                    Button("Open Settings") { SCSystem.openAppSettings() }
                }
            } message: {
                Text(coordinator.alertMessage)
            }
            .sheet(item: $coordinator.activeSheet) { sheet in
                switch sheet {
                case .share(let items):
                    SCShareSheet(items: items)
                case .safari(let url):
                    SCSafariView(url: url)
                case .reportWizard(let scanId):
                    SCReportWizardLauncher(scanId: scanId)
                case .scanDetail(let scanId):
                    SCScanDetailLauncher(scanId: scanId)
                case .legal(let kind):
                    SCLegalView(kind: kind)
                case .permissions:
                    SCPermissionsHelpView()
                case .toastDebug:
                    SCToastDebugView()
                }
            }
            .overlay(alignment: .top) {
                if coordinator.toastVisible {
                    SCToastBanner(text: coordinator.toastText, symbol: coordinator.toastSymbol)
                        .transition(.move(edge: .top).combined(with: .opacity))
                        .padding(.top, 12)
                }
            }
    }
}

