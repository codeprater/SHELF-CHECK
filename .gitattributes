// MARK: - Coordinator (1) Continuity System

@MainActor
final class SCAppCoordinator: ObservableObject {
    static let shared = SCAppCoordinator()

    enum Sheet: Identifiable {
        case share([Any])
        case safari(URL)
        case reportWizard(UUID)      // scanId
        case scanDetail(UUID)        // scanId
        case legal(SCLegalKind)
        case permissions
        case toastDebug

        var id: String {
            switch self {
            case .share:
                return "share"
            case .safari(let url):
                return "safari:\(url.absoluteString)"
            case .reportWizard(let id):
                return "report:\(id.uuidString)"
            case .scanDetail(let id):
                return "scan:\(id.uuidString)"
            case .legal(let kind):
                return "legal:\(kind.rawValue)"
            case .permissions:
                return "permissions"
            case .toastDebug:
                return "toastDebug"
            }
        }
    }

    @Published var activeSheet: Sheet?
    @Published var showingAlert: Bool = false
    @Published var alertTitle: String = ""
    @Published var alertMessage: String = ""
    @Published var alertHasSettingsLink: Bool = false

    @Published var toastVisible: Bool = false
    @Published var toastText: String = ""
    @Published var toastSymbol: String = "checkmark.circle.fill"

    private var toastTask: Task<Void, Never>?

    func bootstrap() {
        // Run once on launch (safe, idempotent).
        SCNotifications.ensureCategories()
    }

    func presentAlert(title: String, message: String, settingsLink: Bool = false) {
        alertTitle = title
        alertMessage = message
        alertHasSettingsLink = settingsLink
        showingAlert = true
    }

    func presentToast(_ text: String, symbol: String = "checkmark.circle.fill") {
        toastTask?.cancel()
        toastText = text
        toastSymbol = symbol
        withAnimation { toastVisible = true }
        toastTask = Task { @MainActor in
            try? await Task.sleep(nanoseconds: 1_800_000_000)
            withAnimation { toastVisible = false }
        }
    }

    func openURL(_ url: URL) {
        activeSheet = .safari(url)
    }

    func share(_ items: [Any]) {
        activeSheet = .share(items)
    }

    func openReportWizard(scanId: UUID) {
        activeSheet = .reportWizard(scanId)
    }

    func openScanDetail(scanId: UUID) {
        activeSheet = .scanDetail(scanId)
    }

    func openLegal(_ kind: SCLegalKind) {
        activeSheet = .legal(kind)
    }

    func openPermissionsHelp() {
        activeSheet = .permissions
    }
}

// MARK: - Scan Status Enum

enum SCScanStatus: String, Codable, CaseIterable {
    case fresh = "Fresh"
    case warning = "Approaching Expiry"
    case expired = "EXPIRED"
    case recalled = "RECALLED"
    case misbranded = "Misbranded (Bulk Break)"
    case tampered = "Label Tampered"
    case unknown = "Unknown"

    var color: Color {
        switch self {
        case .fresh: return SCTheme.freshGreen
        case .warning: return SCTheme.warningYellow
        case .expired: return SCTheme.justiceRed
        case .recalled: return .purple
        case .misbranded: return .orange
        case .tampered: return .red
        case .unknown: return .gray
        }
    }

    var icon: String {
        switch self {
        case .fresh: return "checkmark.seal.fill"
        case .expired: return "xmark.octagon.fill"
        case .misbranded: return "hand.raised.fill"
        case .warning: return "exclamationmark.triangle.fill"
        case .recalled: return "exclamationmark.octagon.fill"
        case .tampered: return "scissors"
        case .unknown: return "questionmark.circle.fill"
        }
    }

    var quickWhy: String {
        switch self {
        case .fresh: return "Decoded date is safely in the future."
        case .warning: return "Decoded date is within the next 30 days."
        case .expired: return "Decoded date is in the past."
        case .recalled: return "This appears to match an active recall alert."
        case .misbranded: return "Text suggests bulk-break or resale restriction."
        case .tampered: return "Text patterns suggest label alteration."
        case .unknown: return "No clear date/violation pattern detected."
        }
    }
}

