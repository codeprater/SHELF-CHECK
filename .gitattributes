// MARK: - (3) PDF Builder

enum SCEvidencePackPDF {
    static func buildPDF(title: String, bodyText: String, attachments: [(String, String, Data)]) -> Data {
        let page = CGRect(x: 0, y: 0, width: 612, height: 792) // US Letter @ 72dpi
        let renderer = UIGraphicsPDFRenderer(bounds: page)

        let data = renderer.pdfData { ctx in
            ctx.beginPage()
            var y: CGFloat = 36

            func draw(_ str: String, font: UIFont, color: UIColor = .black) {
                let attrs: [NSAttributedString.Key: Any] = [
                    .font: font,
                    .foregroundColor: color
                ]
                let maxRect = CGRect(x: 36, y: y, width: page.width - 72, height: page.height - 72)
                let rect = (str as NSString).boundingRect(with: maxRect.size, options: [.usesLineFragmentOrigin, .usesFontLeading], attributes: attrs, context: nil)
                (str as NSString).draw(in: CGRect(x: 36, y: y, width: maxRect.width, height: rect.height), withAttributes: attrs)
                y += rect.height + 10
            }

            draw(title, font: .boldSystemFont(ofSize: 22), color: UIColor(SCTheme.justiceRed))
            draw(bodyText, font: .systemFont(ofSize: 11))

            // Attachments thumbnails (if images)
            if !attachments.isEmpty {
                if y > page.height - 220 {
                    ctx.beginPage()
                    y = 36
                }
                draw("ATTACHMENTS (thumbnails)", font: .boldSystemFont(ofSize: 14), color: UIColor.darkGray)

                let thumbSize = CGSize(width: 160, height: 120)
                var x: CGFloat = 36
                var rowMaxH: CGFloat = 0

                for (name, mime, data) in attachments {
                    if mime.contains("image"), let img = UIImage(data: data) {
                        if x + thumbSize.width > page.width - 36 {
                            x = 36
                            y += rowMaxH + 18
                            rowMaxH = 0
                        }
                        if y + thumbSize.height > page.height - 36 {
                            ctx.beginPage()
                            y = 36
                            x = 36
                            rowMaxH = 0
                        }

                        let rect = CGRect(x: x, y: y, width: thumbSize.width, height: thumbSize.height)
                        img.draw(in: rect)

                        let cap = "\(name)"
                        let attrs: [NSAttributedString.Key: Any] = [
                            .font: UIFont.systemFont(ofSize: 9),
                            .foregroundColor: UIColor.darkGray
                        ]
                        (cap as NSString).draw(in: CGRect(x: x, y: y + thumbSize.height + 2, width: thumbSize.width, height: 12), withAttributes: attrs)

                        rowMaxH = max(rowMaxH, thumbSize.height + 14)
                        x += thumbSize.width + 14
                    } else {
                        // Non-image: list it
                        draw("• \(name) (\(mime))", font: .systemFont(ofSize: 11), color: UIColor.darkGray)
                    }
                }
            }
        }

        return data
    }
}

// MARK: - (5) Store Signal Pipeline

enum SCStoreSignal {
    static func upsertFlaggedStore(
        modelContext: ModelContext,
        storeName: String,
        storeAddress: String,
        lat: Double?,
        lon: Double?
    ) {
        let name = storeName.trimmingCharacters(in: .whitespacesAndNewlines)
        let addr = storeAddress.trimmingCharacters(in: .whitespacesAndNewlines)

        guard !name.isEmpty else { return }

        // If no coordinates, we still store but map may be limited.
        let latitude = lat ?? 42.3314
        let longitude = lon ?? -83.0458

        let fetch = FetchDescriptor<SCFlaggedStore>(predicate: #Predicate {
            $0.name == name && $0.address == addr
        })

        if let existing = try? modelContext.fetch(fetch).first {
            existing.violationCount += 1
            existing.lastViolationDate = Date()
        } else {
            let store = SCFlaggedStore(name: name, address: addr.isEmpty ? "(address not provided)" : addr, lat: latitude, long: longitude)
            modelContext.insert(store)
        }

        try? modelContext.save()
    }
}

