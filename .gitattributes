struct HistoryView: View {
    @Query(sort: \SCStoredScan.timestamp, order: .reverse) private var scans: [SCStoredScan]
    @AppStorage("isDarkMode") private var isDarkMode = true
    @Environment(\.modelContext) private var modelContext
    @EnvironmentObject private var coordinator: SCAppCoordinator

    @State private var search: String = ""
    @State private var filter: SCScanStatus? = nil
    @State private var showUndo: Bool = false
    @State private var lastDeleted: SCStoredScan? = nil

    private var filteredScans: [SCStoredScan] {
        var items = scans
        if let filter { items = items.filter { $0.status == filter } }
        if !search.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty {
            let s = search.lowercased()
            items = items.filter { $0.rawText.lowercased().contains(s) || ($0.storeName ?? "").lowercased().contains(s) }
        }
        return items
    }

    var body: some View {
        NavigationStack {
            ZStack {
                SCTheme.backgroundGradient(isDark: isDarkMode).ignoresSafeArea()

                VStack(spacing: 0) {
                    filterBar
                    if filteredScans.isEmpty {
                        emptyStateView
                    } else {
                        scansList
                    }
                }
            }
            .navigationTitle("Scan History")
            .toolbar {
                ToolbarItem(placement: .topBarTrailing) {
                    Button {
                        filter = nil
                        search = ""
                    } label: {
                        Image(systemName: "line.3.horizontal.decrease.circle")
                    }
                    .accessibilityLabel("Clear filters")
                }
            }
            .overlay(alignment: .bottom) {
                if showUndo {
                    undoBanner
