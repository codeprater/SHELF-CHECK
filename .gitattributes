    // MARK: - Draft wiring

    private func ensureProfile() {
        if profiles.isEmpty {
            modelContext.insert(SCUserProfile())
        }
        if settings.isEmpty {
            modelContext.insert(SCUserSettings())
        }
    }

    private func loadOrCreateDraft() {
        if let existingId = scan.reportDraftId {
            // Load existing draft
            let fetch = FetchDescriptor<SCReportDraft>(predicate: #Predicate { $0.id == existingId })
            if let existing = try? modelContext.fetch(fetch).first {
                draft = existing
                return
            }
        }

        // Create new draft
        let d = SCReportDraft(scanId: scan.id)
        modelContext.insert(d)
        scan.reportDraftId = d.id
        draft = d
        saveContext()
    }

    private func hydrateFromDraft() {
        guard let d = draft else { return }
        storeName = d.storeName
        storeAddress = d.storeAddress
        narrative = d.narrative
        resolution = d.requestedResolution
        if let pdf = d.evidencePDFData { pdfPreviewData = pdf }

        // Mirror attachments
        pendingAttachments = d.attachments.map { ($0.filename, $0.mime, $0.data) }
    }

    private func prefillNarrativeIfEmpty() {
        if !narrative.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty { return }

        var parts: [String] = []
        parts.append("I scanned a product label/lot code that ShelfCheck flagged as \(scan.status.rawValue).")
        if let date = scan.decodedDate {
            parts.append("Decoded date: \(date.formatted(date: .long, time: .omitted)).")
        }
        parts.append("The product appears to be offered for sale despite this.")
        parts.append("Please review the evidence and take immediate corrective action.")

        narrative = parts.joined(separator: " ")
    }

    private func persistDraft() {
        guard let d = draft else { return }
        d.updatedAt = Date()
        d.storeName = storeName.trimmingCharacters(in: .whitespacesAndNewlines)
        d.storeAddress = storeAddress.trimmingCharacters(in: .whitespacesAndNewlines)
        d.narrative = narrative.trimmingCharacters(in: .whitespacesAndNewlines)
        d.requestedResolution = resolution.trimmingCharacters(in: .whitespacesAndNewlines)

        // Replace attachment models
        d.attachments.forEach { modelContext.delete($0) }
        d.attachments.removeAll()

        for att in pendingAttachments {
            let model = SCAttachment(filename: att.0, mime: att.1, data: att.2, reportDraft: d)
            modelContext.insert(model)
            d.attachments.append(model)
        }

        saveContext()
    }

    private func saveContext() {
        do { try modelContext.save() } catch { /* no crash */ }
    }

    // MARK: - Attachment loading

    private func loadPhotosPickerItems(_ items: [PhotosPickerItem]) async {
        var newOnes: [(String, String, Data)] = []
        for (idx, item) in items.enumerated() {
            if let data = try? await item.loadTransferable(type: Data.self) {
                let name = "photo-\(idx + 1).jpg"
                newOnes.append((name, "image/jpeg", data))
            }
        }
        await MainActor.run {
            // keep unique-ish by data hash
            for att in newOnes {
                if pendingAttachments.contains(where: { $0.2 == att.2 }) == false {
                    pendingAttachments.append(att)
                }
            }
            persistDraft()
        }
    }

    // MARK: - Evidence Pack PDF

    private func generateEvidencePack() async {
        await MainActor.run { isGenerating = true }
        defer { Task { @MainActor in isGenerating = false } }

        persistDraft()

        guard let d = draft else { return }

        // location
        let locText: String = {
            if includeLocation, let lat = scan.locationLat, let lon = scan.locationLong {
                return "\(lat.rounded(to: 4)), \(lon.rounded(to: 4))"
            }
            return "Not included"
        }()

        let profile = profiles.first ?? SCUserProfile()
        let anonymous = profile.preferAnonymous

        // Build plain report text (will be embedded into PDF)
        var lines: [String] = []
        lines.append("SHELFCHECK — EVIDENCE PACK")
        lines.append("Generated: \(Date().formatted(date: .long, time: .shortened))")
        lines.append("")
        lines.append("STATUS: \(scan.status.rawValue)")
        lines.append("WHY: \(scan.status.quickWhy)")
        lines.append("")
        lines.append("SCAN RAW:")
        lines.append(scan.rawText)
        lines.append("")
        if let date = scan.decodedDate {
            lines.append("DECODED DATE: \(date.formatted(date: .long, time: .omitted))")
            lines.append("FORMAT: \(scan.decodeFormatUsed)")
            lines.append("CONFIDENCE: \(Int((scan.decodeConfidence * 100).rounded()))%")
            if let m = scan.matchedSubstring { lines.append("MATCHED: \(m)") }
            lines.append("")
        }
        lines.append("STORE:")
        lines.append("Name: \(d.storeName.isEmpty ? "(not provided)" : d.storeName)")
        lines.append("Address: \(d.storeAddress.isEmpty ? "(not provided)" : d.storeAddress)")
        lines.append("Location: \(locText)")
        lines.append("")
        lines.append("WHAT HAPPENED:")
        lines.append(d.narrative.isEmpty ? "(not provided)" : d.narrative)
        lines.append("")
        lines.append("REQUESTED RESOLUTION:")
        lines.append(d.requestedResolution.isEmpty ? "(not provided)" : d.requestedResolution)
        lines.append("")
        lines.append("REPORTER:")
        if anonymous {
            lines.append("Anonymous (user chose not to include personal info)")
        } else {
            lines.append("Name: \(profile.displayName)")
            lines.append("Email: \(profile.email)")
            lines.append("Phone: \(profile.phone)")
            lines.append("City/ZIP: \(profile.city) \(profile.zip)")
        }
        lines.append("")
        lines.append("DISCLAIMER:")
        lines.append("ShelfCheck provides consumer education and evidence organization. Not legal advice.")

        let textBlock = lines.joined(separator: "\n")

        // Render PDF (text + thumbnails)
        let pdfData = SCEvidencePackPDF.buildPDF(
            title: "ShelfCheck Evidence Pack",
            bodyText: textBlock,
            attachments: pendingAttachments
        )

        await MainActor.run {
            pdfPreviewData = pdfData
            d.evidencePDFData = pdfData
            d.updatedAt = Date()
            saveContext()
            coordinator.presentToast("Evidence pack generated", symbol: "doc.fill")
        }
    }

    // MARK: - Submit: update scan + store map signal

    private func markSubmittedAndUpdateStoreSignal() {
        persistDraft()
        guard let d = draft else { return }

        d.isSubmitted = true
        d.submittedAt = Date()
        scan.isReported = true

        // Store signal (5): create/increment flagged store if actionable status
        if scan.status == .expired || scan.status == .misbranded || scan.status == .recalled {
            SCStoreSignal.upsertFlaggedStore(
                modelContext: modelContext,
                storeName: d.storeName,
                storeAddress: d.storeAddress,
                lat: scan.locationLat,
                lon: scan.locationLong
            )
        }

        saveContext()
        coordinator.presentToast("Marked submitted + updated map", symbol: "checkmark.seal.fill")
        dismiss()
    }
}

