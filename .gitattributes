struct SCReminderSheet: View {
    let scan: SCStoredScan
    @Binding var reminderDaysBefore: Int

    @Environment(\.dismiss) private var dismiss
    @EnvironmentObject private var coordinator: SCAppCoordinator
    @Query private var settings: [SCUserSettings]

    var body: some View {
        NavigationStack {
            Form {
                Section("Reminder Timing") {
                    Stepper(value: $reminderDaysBefore, in: 1...30) {
                        Text("\(reminderDaysBefore) day(s) before")
                    }
                    .disabled(scan.decodedDate == nil)
                }

                Section("Preview") {
                    if let exp = scan.decodedDate {
                        let remindDate = Calendar.current.date(byAdding: .day, value: -reminderDaysBefore, to: exp) ?? exp
                        Text("Will notify on \(remindDate.formatted(date: .long, time: .omitted))")
                            .font(.subheadline)
                    } else {
                        Text("No decoded date. Scan a date first.")
                            .font(.subheadline)
                            .foregroundStyle(.secondary)
                    }
                }
            }
            .navigationTitle("Expiry Reminder")
            .toolbar {
                ToolbarItem(placement: .topBarLeading) {
                    Button("Cancel") { dismiss() }
                }
                ToolbarItem(placement: .topBarTrailing) {
                    Button("Set") {
                        guard let exp = scan.decodedDate else { return }
                        let enabled = settings.first?.enableExpiryReminders ?? true
                        if !enabled {
                            coordinator.presentAlert(title: "Reminders Off", message: "Enable expiry reminders in Settings.")
                            return
                        }
                        Task { await SCNotifications.requestAuthIfNeeded(coordinator: coordinator) }
                        let remindDate = Calendar.current.date(byAdding: .day, value: -reminderDaysBefore, to: exp) ?? exp
                        SCNotifications.scheduleExpiryReminder(scanId: scan.id, fireDate: remindDate, title: "ShelfCheck Reminder", body: "This item expires soon. Review your scan and take action.")
                        coordinator.presentToast("Reminder scheduled", symbol: "bell.fill")
                        dismiss()
                    }
                }
            }
        }
    }
}

