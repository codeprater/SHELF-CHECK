@Model
final class SCRecallAlert {
    @Attribute(.unique) var id: String
    var product: String
    var reason: String
    var dateIssued: Date
    var source: String
    var lotCodesData: Data?

    var lotCodes: [String] {
        get {
            guard let data = lotCodesData else { return [] }
            return (try? JSONDecoder().decode([String].self, from: data)) ?? []
        }
        set {
            lotCodesData = try? JSONEncoder().encode(newValue)
        }
    }

    init(id: String, product: String, reason: String, dateIssued: Date, source: String, lotCodes: [String]) {
        self.id = id
        self.product = product
        self.reason = reason
        self.dateIssued = dateIssued
        self.source = source
        self.lotCodesData = try? JSONEncoder().encode(lotCodes)
    }
}

