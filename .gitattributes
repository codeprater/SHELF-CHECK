                        .padding(.bottom, 12)
                }
            }
        }
    }

    private var filterBar: some View {
        VStack(spacing: 10) {
            HStack {
                Image(systemName: "magnifyingglass")
                    .foregroundStyle(.secondary)
                TextField("Search scans or stores", text: $search)
                    .textFieldStyle(.plain)
            }
            .padding(10)
            .background(.ultraThinMaterial)
            .cornerRadius(14)
            .padding(.horizontal)

            ScrollView(.horizontal, showsIndicators: false) {
                HStack(spacing: 10) {
                    SCFilterChip(title: "All", isOn: filter == nil) { filter = nil }
                    ForEach([SCScanStatus.expired, .warning, .misbranded, .recalled, .fresh], id: \.self) { st in
                        SCFilterChip(title: st.rawValue, isOn: filter == st, color: st.color) { filter = st }
                    }
                }
                .padding(.horizontal)
                .padding(.bottom, 10)
            }
        }
        .padding(.top, 10)
    }

    private var emptyStateView: some View {
        VStack(spacing: 16) {
            Image(systemName: "clock.arrow.circlepath")
                .font(.system(size: 50))
                .foregroundStyle(.secondary)
            Text("No Scans Yet")
                .font(.headline)
            Text("Your scan history will appear here. Tap a scan for details and actions.")
                .font(.caption)
                .foregroundStyle(.secondary)
                .multilineTextAlignment(.center)
                .padding(.horizontal)
        }
        .frame(maxWidth: .infinity, maxHeight: .infinity)
    }

    private var scansList: some View {
        List {
            ForEach(filteredScans) { scan in
                Button {
                    coordinator.openScanDetail(scanId: scan.id)
                } label: {
                    HStack(spacing: 12) {
                        Image(systemName: scan.status.icon)
                            .foregroundStyle(scan.status.color)
                            .font(.title2)
                            .frame(width: 30)

                        VStack(alignment: .leading, spacing: 4) {
                            Text(scan.status.rawValue)
                                .font(.headline)
                            Text(scan.rawText)
                                .font(.caption)
                                .foregroundStyle(.secondary)
                                .lineLimit(1)

                            if let date = scan.decodedDate {
                                Text("Decoded: \(date.formatted(date: .abbreviated, time: .omitted)) · \(Int((scan.decodeConfidence * 100).rounded()))%")
                                    .font(.caption2)
                                    .foregroundStyle(scan.status.color)
                            }
                        }

                        Spacer()

                        Image(systemName: "chevron.right")
                            .foregroundStyle(.secondary)
                    }
                    .padding(.vertical, 6)
                }
                .listRowBackground(SCTheme.cardBackground(isDark: isDarkMode))
            }
            .onDelete(perform: deleteScans)
        }
        .scrollContentBackground(.hidden)
    }

    private func deleteScans(at offsets: IndexSet) {
        for index in offsets {
            lastDeleted = filteredScans[index]
            modelContext.delete(filteredScans[index])
        }
        try? modelContext.save()
        withAnimation { showUndo = true }
        DispatchQueue.main.asyncAfter(deadline: .now() + 4) {
            withAnimation { showUndo = false }
        }
    }

    private var undoBanner: some View {
        HStack {
            Text("Scan deleted")
                .font(.subheadline.weight(.semibold))
                .foregroundStyle(.white)
            Spacer()
            Button("Undo") {
                if let scan = lastDeleted {
                    modelContext.insert(scan)
                    try? modelContext.save()
                }
                withAnimation { showUndo = false }
            }
            .font(.subheadline.weight(.bold))
            .foregroundStyle(.white)
        }
        .padding()
        .background(.black.opacity(0.85))
        .cornerRadius(14)
        .padding(.horizontal)
    }
